# URL del backend (producción: https://api.tudominio.com)
VITE_API_URL=https://api.tudominio.com

# Google OAuth Client ID
# 1. Ve a https://console.cloud.google.com/apis/credentials
# 2. Crea un "OAuth client ID" tipo "Web application"
# 3. Agrega las URLs de producción como Authorized JavaScript origins
#    https://tudominio.com
#    https://www.tudominio.com
# 4. Copia el Client ID aquí:
VITE_GOOGLE_CLIENT_ID=tu-client-id-google.apps.googleusercontent.com
