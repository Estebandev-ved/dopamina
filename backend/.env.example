# ============================================================================
#  PLANTILLA DE VARIABLES DE ENTORNO  —  copia este archivo a .env y rellénalo.
#  NUNCA subas el .env real al repositorio (ya está en .gitignore).
# ============================================================================

# Perfil de ejecución: 'dev' (local) o 'prod' (producción).
SPRING_PROFILES_ACTIVE=dev

# --- Base de datos ---
DATABASE_URL=jdbc:mysql://localhost:3306/dopamina_crew_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DATABASE_USER=dopamina_user
DATABASE_PASSWORD=CAMBIA_ESTO

# --- Seguridad JWT ---
# Clave de 256 bits en HEX. Genera una NUEVA para producción, por ejemplo:
#   openssl rand -hex 32
JWT_SECRET=GENERA_UNA_CLAVE_NUEVA_DE_64_CARACTERES_HEX

# --- CORS (orígenes permitidos, separados por coma) ---
# En prod: tus dominios reales con https. Ej:
# CORS_ALLOWED_ORIGINS=https://dopaminacrew.com,https://www.dopaminacrew.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Pasarela de pago Efipay ---
EFIPAY_API_URL=https://sag.efipay.co/api/v1
EFIPAY_ACCESS_TOKEN=
EFIPAY_OFFICE_ID=
EFIPAY_WEBHOOK_TOKEN=
EFIPAY_COMMERCE_ID=
EFIPAY_CHECKOUT_TEMPLATE_ID=
# URL del frontend (para redirección post-pago). En prod: https://tudominio.com
EFIPAY_REDIRECT_BASE_URL=http://localhost:5173
# URL pública del backend (para el webhook). En prod: https://api.tudominio.com
EFIPAY_BACKEND_BASE_URL=http://localhost:8080

# --- Emails (Resend) ---
RESEND_API_KEY=
RESEND_ADMIN_EMAIL=admin@dopaminacrew.com
# En producción debe ser false para enviar a clientes reales.
RESEND_TEST_MODE=true
RESEND_TEST_EMAIL=

# --- Google OAuth (frontend) ---
VITE_GOOGLE_CLIENT_ID=

# --- Facebook Conversions API (CAPI) ---
# Obtén el Pixel ID en: https://eventsmanager.facebook.com
FACEBOOK_PIXEL_ID=1667872257652141
# Obtén el Access Token en: Business Settings > Data Sources > Conversions API
FACEBOOK_ACCESS_TOKEN=
